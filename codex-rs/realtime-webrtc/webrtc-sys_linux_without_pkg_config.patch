     let glib_path_config = glib_path_config.join("glib-2.0/include");
     builder.include(&glib_path_config);
 }
+
+fn add_gio_link_flags() {
+    let webrtc_dir = webrtc_sys_build::webrtc_dir();
+    let target_arch = webrtc_sys_build::target_arch();
+    let target_arch_sysroot = match target_arch.as_str() {
+        "arm64" => "arm64",
+        "x64" => "amd64",
+        _ => panic!("unsupported arch"),
+    };
+    let arch_specific_path = match target_arch.as_str() {
+        "x64" => "x86_64-linux-gnu",
+        "arm64" => "aarch64-linux-gnu",
+        _ => panic!("unsupported target"),
+    };
+
+    let sysroot_path = format!("include/build/linux/debian_bullseye_{target_arch_sysroot}-sysroot");
+    let lib_path = webrtc_dir.join(sysroot_path).join("usr/lib").join(arch_specific_path);
+    println!("cargo:rustc-link-search=native={}", lib_path.display());
+
+    for lib_name in ["glib-2.0", "gobject-2.0", "gio-2.0"] {
+        println!("cargo:rustc-link-lib=dylib={lib_name}");
+    }
+}
+
+fn remove_bazel_dangling_cxxbridge_symlink() {
+    let Ok(out_dir) = env::var("OUT_DIR") else {
+        return;
+    };
+    let crate_include = PathBuf::from(out_dir).join("cxxbridge").join("crate").join("webrtc-sys");
+    let Ok(metadata) = std::fs::symlink_metadata(&crate_include) else {
+        return;
+    };
+    if metadata.file_type().is_symlink() {
+        std::fs::remove_file(&crate_include).unwrap_or_else(|err| {
+            panic!("failed to remove generated cxxbridge symlink {}: {err}", crate_include.display())
+        });
+    }
+}
